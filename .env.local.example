# Copy this file to .env.local and fill in your Supabase project values.
# After saving .env.local, stop the dev server (Ctrl+C) and run: npm run dev

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# Required for Artist Recommendations (taste matching — server-only)
# Free key: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key

# Required to show venues when you tap a recommended artist (server-only)
# Free key: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key
